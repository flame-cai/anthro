{
  "name": "@flame-cai/anthro",
  "version": "2.1.0",
  "description": "WHO 2006 Child Growth Standards — z-scores & classifications. Dual-mode: day-indexed (WHO igrowup) and month-indexed tables.",
  "main": "src/anthro.js",
  "types": "src/anthro.d.ts",
  "files": ["src/", "data/", "README.md", "LICENSE", "CHANGELOG.md"],
  "keywords": ["who","child-growth","anthropometry","z-score","stunting","wasting","underweight","muac","lhfa","wfa","wflh","bmi","acfa","igrowup"],
  "license": "MIT",
  "scripts": {
    "test":  "node test/anthro.test.js",
    "build": "esbuild src/anthro.js --bundle --format=iife --global-name=anthro --outfile=docs/anthro.bundle.js --minify && cp data/*.json docs/data/",
    "dev":   "npx serve docs"
  },
  "engines": { "node": ">=14" },
  "devDependencies": { "esbuild": "^0.20.0" },
  "repository": { "type": "git", "url": "https://github.com/flame-cai/anthro.git" },
  "homepage": "https://flame-cai.github.io/anthro",
  "bugs": { "url": "https://github.com/flame-cai/anthro/issues" }
}
