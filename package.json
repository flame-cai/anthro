{
  "name": "@flame-cai/anthro",
  "version": "1.0.1",
  "description": "WHO 2006 Child Growth Standards — z-scores and classifications for 6 indicators",
  "main": "src/anthro.js",
  "types": "src/anthro.d.ts",
  "files": [
    "src/",
    "data/",
    "README.md"
  ],
  "keywords": [
    "who",
    "child-growth",
    "anthropometry",
    "z-score",
    "stunting",
    "wasting",
    "underweight",
    "muac",
    "lhfa",
    "wfa",
    "wflh",
    "bmi",
    "acfa",
    "igrowup"
  ],
  "scripts": {
    "test": "node test/anthro.test.js",
    "export-tables": "Rscript scripts/export-tables.R",
    "build": "esbuild src/anthro.js --bundle --format=iife --global-name=anthro --outfile=docs/anthro.bundle.js --minify && mkdir -p docs/data && cp data/*.json docs/data/",
    "sync-version": "node -e \"const v=require('fs').readFileSync('VERSION','utf8').trim();const p=require('./package.json');p.version=v;require('fs').writeFileSync('package.json',JSON.stringify(p,null,2)+'\\n');\""
  },
  "engines": {
    "node": ">=24"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/flame-cai/anthro.git"
  },
  "homepage": "https://flame-cai.github.io/anthro",
  "bugs": {
    "url": "https://github.com/flame-cai/anthro/issues"
  }
}
